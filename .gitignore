# ---------------------------------------------------------
# Общие правила игнорирования для репозитория студента
# ---------------------------------------------------------

# === Системные файлы ОС ===
.DS_Store
Thumbs.db

# === Конфигурации IDE/редакторов ===
.vscode/
.idea/
*.swp
*.swo

# === Виртуальные окружения Python ===
.venv/
venv/
env/
ENV/
.conda/

# === Кеши Python и скомпилированные файлы ===
__pycache__/
*.py[cod]
*$py.class

# === Папки сборки/дистрибуции ===
build/
dist/
eggs/
*.egg-info/
.installed.cfg

# === Кеши и артефакты тестов ===
.pytest_cache/
.coverage
.coverage.*
htmlcov/

# === Журналы ===
*.log
logs/

# === Кеши Jupyter Notebook ===
.ipynb_checkpoints

# === Файлы окружения с потенциальными секретами ===
.env
*.env
.env.*
!.env.example

# === Разное ===
*.tmp
*.bak
*.old

# === Игнорировать папки с данными (большие файлы датасетов) ===
**/data/

# === Игнорировать временные папки отчетов (из старых ДЗ) ===
reports_*/
test_output/

# ML модели (большие файлы)
best_model/
*.pth
*.bin
*.pt
*.h5
*.onnx

# Папки с результатами обучения
results/
checkpoints/

# Временные файлы PyTorch
*.dill